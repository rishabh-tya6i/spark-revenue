# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_db

# Zerodha (Kite Connect)
ZERODHA_API_KEY=your_api_key
ZERODHA_API_SECRET=your_api_secret
ZERODHA_ACCESS_TOKEN=your_access_token

# Upstox
UPSTOX_ACCESS_TOKEN=your_access_token
UPSTOX_API_BASE_URL=https://api.upstox.com
UPSTOX_INSTRUMENTS_JSON_URL=
UPSTOX_UNIVERSE_SEGMENTS=NSE_INDEX,BSE_INDEX
UPSTOX_DEFAULT_SYMBOLS=NIFTY,SENSEX
UPSTOX_HISTORICAL_API_VERSION=v3
UPSTOX_UNIVERSE_INSTRUMENT_TYPES=INDEX

# Binance
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_FEATURE_TTL_SECONDS=300

# Price Prediction Model
PRICE_MODEL_DIR=models/price_model
PRICE_MODEL_INPUT_WINDOW=60
PRICE_MODEL_PREDICTION_HORIZON=12

# RL Agent
RL_AGENT_MODEL_DIR=models/rl_agent
RL_TRAINING_EPISODES=50
RL_MAX_STEPS_PER_EPISODE=500
RL_INITIAL_CAPITAL=100000.0
RL_TRANSACTION_COST_BPS=10.0

# News & Sentiment
NEWS_RSS_FEEDS=  # e.g., https://hnrss.org/frontpage,https://www.reuters.com/rssfeed/healthNews
SENTIMENT_MODEL_NAME=ProsusAI/finbert
SENTIMENT_BATCH_SIZE=16

OPTIONS_DATA_SOURCE=stub  # "nse" implementation coming later
OPTIONS_DEFAULT_EXCHANGE=NSE

# Decision Engine
DECISION_MIN_CONFIDENCE=0.6

# Alerts
ALERT_MIN_IMPORTANCE=0.7
ALERT_CHANNELS=  # e.g., desktop,telegram

# Backtesting
BACKTEST_INITIAL_CAPITAL=100000.0
BACKTEST_TRANSACTION_COST_BPS=10.0
BACKTEST_DEFAULT_INTERVAL=5m
 
# Training & Orchestration
TRAIN_SYMBOLS=BTCUSDT
TRAIN_UNIVERSE_MODE=explicit
TRAIN_MAX_SYMBOLS=10
TRAIN_LOOKBACK_DAYS=30
TRAIN_PREPARE_INTERVAL=
TRAIN_DEFAULT_INTERVAL=5m
TRAIN_DAILY_RUN_HOUR_UTC=3
TRAINABILITY_MIN_BUFFER_BARS=5
 
# Execution & Paper Trading
EXECUTION_MODE=paper
EXECUTION_DEFAULT_SYMBOLS=BTCUSDT
EXECUTION_BASE_CURRENCY=USD
EXECUTION_MAX_POSITION_PER_SYMBOL=1.0
EXECUTION_MAX_NOTIONAL_PER_SYMBOL=20000.0

# Global Operational Guardrails
EXECUTION_ENABLED=true
EXECUTION_MAX_SYMBOLS_PER_RUN=5
EXECUTION_ALLOWED_ACTIONS=BUY,SELL

# Staleness Controls
EXECUTION_MAX_DECISION_AGE_MINUTES=30
EXECUTION_MAX_OVERRIDE_AGE_MINUTES=60
